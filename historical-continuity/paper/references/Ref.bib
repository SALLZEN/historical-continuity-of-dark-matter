@article{allzen_dm_became_particle,
title = {Why, When, and How Dark Matter Became Considered a Particle},
journal = {Under review},
volume = {-},
pages = {01-10},
year = {2025},
author = {Simon Allzén},
abstract = {The current state of belief about the nature of dark matter is that it is a non-baryonic particle (in the quantum field theoretical sense: a local excitation of a quantum field) which interacts little or nothing electromagnetically. This belief is ubiquitous among scientists working in dark matter, but when, how and why did scientists converge to this belief? In this paper I will explore and explain what I call the 'particle turn' of the dark matter hypothesis.}
}
